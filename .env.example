# Zenith AI - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ====================
# GCP Configuration
# ====================
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# ====================
# OAuth 2.0 Credentials
# ====================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth Redirect URI (update for production)
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# ====================
# Vertex AI Configuration
# ====================
VERTEX_AI_MODEL=gemini-2.5-flash
VERTEX_AI_LOCATION=us-central1

# ====================
# JWT Configuration
# ====================
# Generate a secure secret key:
# On Linux/Mac: openssl rand -hex 32
# On Windows: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# ====================
# Application Settings
# ====================
# Set to false in production
DEBUG=true

# ====================
# Optional: Database
# ====================
# If using PostgreSQL instead of Firestore for some data
# DATABASE_URL=postgresql://user:password@localhost:5432/zenith

# ====================
# Optional: Redis
# ====================
# For caching and session storage
# REDIS_URL=redis://localhost:6379/0

# ====================
# Optional: Monitoring
# ====================
# SENTRY_DSN=your-sentry-dsn
# LOG_LEVEL=INFO
